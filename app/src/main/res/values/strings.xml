    <string name="health_score_core_summary">Core health score: %1$d / 10. This uses a strict annual Piotroski F-Score framework with 9 pass/fail tests across profitability, funding discipline, liquidity, and operating efficiency.</string>
    <string name="health_score_growth_summary">Growth score: %1$d / 10. Higher scores indicate stronger and more consistent business expansion.</string>
    <string name="health_score_resilience_summary">Bankruptcy risk checker level: %1$d / 3. Higher levels signal sturdier Altman Z-style resilience.</string>
