    <string name="health_score_core_summary">Core health score: %1$d / 10. This uses a strict annual Piotroski F-Score framework with 9 pass/fail tests across profitability, funding discipline, liquidity, and operating efficiency.</string>
    <string name="health_score_core_summary_with_missing">Core health score: %1$d / 10 (neutral fallback). We are missing data for %2$d of %3$d Piotroski checks, so unavailable checks are marked N/A below.</string>
