    <string name="health_score_rationale_revenue">Revenue size highlights the scale of the company and the dollars available to cover fixed costs.</string>
    <string name="health_score_rationale_net_income">Net income tracks bottom-line profitability and the firms ability to convert revenue into earnings.</string>
    <string name="health_score_rationale_eps">EPS reveals how much profit is available to each share, helping compare earnings power per investor.</string>
    <string name="health_score_rationale_pe_ratio">The P/E ratio benchmarks how richly the market prices each dollar of earnings against peers.</string>
    <string name="health_score_rationale_ps_ratio">The P/S ratio shows whether investors are overpaying or underpaying for each dollar of revenue.</string>
    <string name="health_score_rationale_roe">ROE captures how efficiently management turns shareholder equity into profit.</string>
    <string name="health_score_rationale_debt_to_equity">The debt-to-equity ratio gauges leverage and how reliant the company is on borrowed capital.</string>
    <string name="health_score_rationale_pb_ratio">Price-to-book compares market value to net assets, signalling whether equity is priced at a premium or discount.</string>
    <string name="health_score_rationale_ebitda">EBITDA is calculated as operating income plus depreciation and amortization from EDGAR facts, not read from a standalone EBITDA tag.</string>
    <string name="health_score_rationale_free_cash_flow">Free cash flow is operating cash flow minus the absolute value of capital expenditures, and only when both are reported for that period. We never substitute operating cash flow alone.</string>
    <string name="health_score_rationale_operating_cash_flow">Operating cash flow reveals the health of core operations independent of financing and investing flows.</string>
    <string name="health_score_rationale_free_cash_flow_margin">Free cash flow margin divides the same derived FCF by revenue; it stays N/A when FCF cannot be computed because OCF or capex is missing.</string>
    <string name="health_score_rationale_net_margin">Net margin shows the share of each dollar of sales that drops to the bottom line.</string>
    <string name="health_score_rationale_ebitda_margin">EBITDA margin uses reported EBITDA when present; it is N/A when the filer does not report EBITDA.</string>
    <string name="health_score_rationale_current_ratio">The current ratio tests near-term liquidity by comparing short-term assets to liabilities.</string>
    <string name="health_score_rationale_liability_to_asset_ratio">Liability-to-asset ratio signals solvency by showing how much of the asset base is financed with debt.</string>
    <string name="health_score_rationale_working_capital_ratio">Working capital ratio spotlights the cushion of short-term resources relative to the asset base.</string>
    <string name="health_score_rationale_retained_earnings">Retained earnings reflect the cumulative profits reinvested back into the business.</string>
    <string name="health_score_rationale_outstanding_shares">Outstanding shares influence per-share metrics and investor dilution risk.</string>
    <string name="health_score_rationale_total_assets">Total assets capture the productive base supporting revenue and cash flow.</string>
    <string name="health_score_rationale_total_liabilities">Total liabilities show the obligations that claims cash flow before equity holders.</string>

    <string name="health_score_rationale_avg_revenue_growth">Average revenue growth smooths out volatility to show the long-term top-line trend.</string>
    <string name="health_score_rationale_avg_net_income_growth">Average net income growth tracks whether profitability is improving over time.</string>
    <string name="health_score_rationale_recent_net_income_growth">Recent net income growth captures the latest profitability trend versus last year.</string>
    <string name="health_score_rationale_fcf_growth">Year-over-year FCF growth is scored only from derived FCF series; missing years or periods without both OCF and capex reduce or remove this signal.</string>
    <string name="health_score_rationale_avg_fcf_growth">Multi-year average FCF growth uses the same rule as FCF: each point needs operating cash flow and capex. Sparse history means a weaker or absent trend.</string>
    <string name="health_score_rationale_recent_revenue_growth">Latest revenue growth reveals current momentum in sales.</string>
    <string name="health_score_rationale_ocf_growth_combined">Operating cash flow (OCF) is a more stable cash signal because it is measured before capex. Scoring both OCF YoY and multi-year average helps confirm growth is cash-backed and less sensitive to lumpy equipment spending.</string>
    <string name="health_score_rationale_free_cash_flow_margin_growth">Sustained FCF margins indicate cash-backed growth only when FCF itself is computable for those periods.</string>
    <string name="health_score_rationale_ebitda_margin_trend">EBITDA margin trend uses calculated EBITDA for each year; gaps appear when operating income or D&amp;A is missing for a period.</string>
    <string name="health_score_rationale_gross_profit_margin_growth">Gross profit margin growth detects whether revenue growth is "growing into losses". Positive values indicate margin expansion; negative values indicate compressing gross margins despite higher sales.</string>

    <string name="metric_piotroski_positive_roa">Positive ROA / profitability</string>
    <string name="metric_piotroski_positive_cfo">Positive operating cash flow</string>
    <string name="metric_piotroski_operating_income_sign_matches_net_income">Operating income sign matches net income sign</string>
    <string name="metric_piotroski_accrual_quality">Operating cash flow exceeds net income</string>
    <string name="metric_piotroski_ocf_to_net_income_gt_one">Operating cash flow / net income is greater than 1.0</string>
    <string name="metric_piotroski_non_operating_income_share_lt_50pct">Non-operating income is less than 50% of net income</string>
    <string name="metric_piotroski_no_dilution">No new shares issued</string>
    <string name="metric_piotroski_margin_improved">Higher gross margin vs prior year</string>
    <string name="metric_piotroski_asset_turnover_improved">Higher asset turnover vs prior year</string>

    <string name="health_score_rationale_piotroski_positive_roa">Passes when profitability relative to assets is positive.</string>
    <string name="health_score_rationale_piotroski_positive_cfo">Passes when operating cash flow is positive.</string>
    <string name="health_score_rationale_piotroski_operating_income_sign_matches_net_income">Passes when operating income and net income have the same sign, reducing the chance that non-operating items dominate reported earnings direction.</string>
    <string name="health_score_rationale_piotroski_accrual_quality">Passes when operating cash flow is greater than reported net income, signaling stronger earnings quality.</string>
    <string name="health_score_rationale_piotroski_ocf_to_net_income_gt_one">Passes when both operating cash flow and net income are positive and operating cash flow is greater than net income (ratio above 1.0), indicating stronger cash backing of profit.</string>
    <string name="health_score_rationale_piotroski_non_operating_income_share_lt_50pct">Passes when net income is positive and non-operating income contributes less than half of net income, reducing dependence on non-core or non-recurring gains.</string>
    <string name="health_score_rationale_piotroski_no_dilution">Passes when annual shares outstanding did not increase versus the prior fiscal year.</string>
    <string name="health_score_rationale_piotroski_margin_improved">Passes when annual gross margin is higher than the prior fiscal year.</string>
    <string name="health_score_rationale_piotroski_asset_turnover_improved">Passes when annual revenue generated per dollar of assets is higher than the prior fiscal year.</string>

    <string name="health_score_rationale_working_capital_to_assets">Working capital to assets measures liquidity strength after inventory and receivables.</string>
    <string name="health_score_rationale_retained_earnings_to_assets">Retained earnings to assets shows how much of the asset base was financed by cumulative profits.</string>
